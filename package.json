{
  "name": "linkripper",
  "version": "0.1.0",
  "private": true,
  "description": "LINKRIPPER — a personal, self-hosted web archive built on Steel",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx scripts/e2e-capture.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.4",
    "jsdom": "^25.0.1",
    "nanoid": "^5.0.9",
    "next": "15.1.6",
    "puppeteer-core": "^23.11.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "^0.33.5",
    "steel-sdk": "^0.7.0",
    "thumbhash": "^0.1.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/turndown": "^5.0.6",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.2",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
