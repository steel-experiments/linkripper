# LINKRIPPER configuration — copy to .env and fill in.

# --- Steel (the browser engine that captures pages) ---
# Option A: Steel Cloud. Get a key at https://app.steel.dev — leave STEEL_BASE_URL unset.
STEEL_API_KEY=

# Option B: fully self-hosted steel-browser (docker). Point at your instance and
# you can leave STEEL_API_KEY blank. See docker-compose.yml.
# STEEL_BASE_URL=http://localhost:3000

# When a Cloudflare/Turnstile challenge is detected, LINKRIPPER escalates to a
# solveCaptcha session (Steel Cloud only). Set to "true" to also route that
# session through a Steel residential proxy (helps with Cloudflare; requires a
# paid plan, otherwise leave unset to avoid HTTP 402).
# STEEL_USE_PROXY=true

# Milliseconds to wait after navigation before capturing, so late-loading images
# and content settle. Bump for image-heavy pages. Default 3000.
# STEEL_CAPTURE_DELAY=3000

# Route every capture through a session that auto-scrolls the page first, so
# scroll-lazy (IntersectionObserver) images load before the screenshot. Captures
# everything, but is slower/costlier per page. Default off.
# STEEL_SCROLL_CAPTURE=true

# --- Storage ---
# Where the SQLite DB and page blobs live. Defaults to ./data.
DATA_DIR=./data
DATABASE_PATH=./data/linkripper.db
